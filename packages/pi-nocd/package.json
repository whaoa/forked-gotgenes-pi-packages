{
  "name": "@gotgenes/pi-nocd",
  "version": "1.0.0",
  "description": "Pi extension that injects the resolved working directory into the system prompt so the agent never cd-prefixes the current working directory",
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "system-prompt",
    "cwd"
  ],
  "author": {
    "name": "Chris Lasher"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gotgenes/pi-packages.git",
    "directory": "packages/pi-nocd"
  },
  "bugs": {
    "url": "https://github.com/gotgenes/pi-packages/issues"
  },
  "homepage": "https://github.com/gotgenes/pi-packages/tree/main/packages/pi-nocd#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "check": "tsc --noEmit",
    "lint": "biome check . && eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@earendil-works/pi-coding-agent": "0.79.1",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.75.0"
  }
}
