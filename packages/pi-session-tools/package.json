{
  "name": "@gotgenes/pi-session-tools",
  "version": "1.1.0",
  "description": "Pi extension providing session metadata tools (naming, context) for multi-session workflows",
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "session",
    "workflow"
  ],
  "author": {
    "name": "Chris Lasher"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gotgenes/pi-packages.git",
    "directory": "packages/pi-session-tools"
  },
  "bugs": {
    "url": "https://github.com/gotgenes/pi-packages/issues"
  },
  "homepage": "https://github.com/gotgenes/pi-packages/tree/main/packages/pi-session-tools#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "check": "tsc --noEmit",
    "lint": "biome check . && eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@earendil-works/pi-ai": "0.79.1",
    "@earendil-works/pi-coding-agent": "0.79.1",
    "@earendil-works/pi-tui": "0.79.1",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.75.0",
    "@earendil-works/pi-coding-agent": ">=0.75.0",
    "@earendil-works/pi-tui": ">=0.75.0"
  }
}
