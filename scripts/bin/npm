#!/bin/sh
# PATH shim: intercepts `npm` and redirects to `pnpm`
#
# This file is injected ahead of the real `npm` binary via [env] _.path in mise.toml.
# It activates for all sessions (agent and developer) within the project directory.
#
# Exceptions passed through to the real npm:
#   - `npm root` — the extension calls `npm root -g` at startup to discover
#     the global node_modules directory where Pi installs skills/extensions.
#   - any invocation with a `*/.pi/npm` argument — Pi itself runs
#     `npm install/uninstall --prefix <project>/.pi/npm` to manage extensions.
#   - `npm install -g` / `npm uninstall -g` — Pi manages global packages
#     this way. Global operations don't affect the project lockfile.
#
# To bypass this shim in an emergency: use the full path to npm, e.g.
#   $(mise where node)/bin/npm ...

# Save original arguments before any positional-parameter manipulation.
ORIG_ARGS="$*"
SUBCMD="${1:-}"

# ── Locate the real npm binary (skip this shim in PATH) ────────────────────
SELF="$(cd "$(dirname "$0")" && pwd)/npm"
REAL_NPM=""
OIFS="$IFS"; IFS=":"; set -- $PATH; IFS="$OIFS"
for dir in "$@"; do
  candidate="$dir/npm"
  if [ -x "$candidate" ] && [ "$candidate" != "$SELF" ]; then
    REAL_NPM="$candidate"
    break
  fi
done
set -- $ORIG_ARGS
SUBCMD="${1:-}"

pass_through() {
  if [ -z "$REAL_NPM" ]; then
    echo "npm shim: could not find real npm binary" >&2
    exit 1
  fi
  # shellcheck disable=SC2086
  exec "$REAL_NPM" $ORIG_ARGS
}

# ── Pass-through: Pi internal package management (.pi/npm) ─────────────────
# Pi itself runs `npm install/uninstall --prefix <project>/.pi/npm` to manage
# extensions. Any subcommand with a .pi/npm path is passed through.
for arg in $ORIG_ARGS; do
  case "$arg" in
    */.pi/npm|*/.pi/npm/) pass_through ;;
  esac
done

# ── Pass-through: global installs/uninstalls ────────────────────────────────
# Pi runs `npm install -g <pkg>` and `npm uninstall -g <pkg>` for global
# package management. Global operations don't affect the project lockfile.
case "$SUBCMD" in
  install|i|add|uninstall|remove|rm|un)
    for arg in $ORIG_ARGS; do
      case "$arg" in
        -g|--global) pass_through ;;
      esac
    done
    ;;
esac

# ── Pass-through: read-only queries ─────────────────────────────────────────
case "$SUBCMD" in
  root) pass_through ;;
esac

# ── Block everything else ──────────────────────────────────────────────────
BOLD="\033[1m"
RED="\033[31m"
YELLOW="\033[33m"
RESET="\033[0m"

echo "" >&2
echo "${RED}${BOLD}✗ npm is not allowed in this project.${RESET}" >&2
echo "" >&2
echo "  Use ${BOLD}pnpm${RESET} instead." >&2
echo "" >&2

case "$SUBCMD" in
  install|i|add|ci)
    echo "  You ran:    npm $ORIG_ARGS" >&2
    echo "  Use this:   ${YELLOW}${BOLD}pnpm install${RESET}" >&2
    ;;
  run|exec)
    SCRIPT="${2:-<script>}"
    echo "  You ran:    npm $ORIG_ARGS" >&2
    echo "  Use this:   ${YELLOW}${BOLD}pnpm run ${SCRIPT}${RESET}" >&2
    ;;
  test|t)
    echo "  You ran:    npm $ORIG_ARGS" >&2
    echo "  Use this:   ${YELLOW}${BOLD}pnpm run test${RESET}" >&2
    ;;
  *)
    if [ -n "$SUBCMD" ]; then
      echo "  You ran:    npm $ORIG_ARGS" >&2
    fi
    echo "  See AGENTS.md for pnpm conventions." >&2
    ;;
esac

echo "" >&2
exit 1
