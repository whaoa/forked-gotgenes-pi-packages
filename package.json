{
  "private": true,
  "name": "@gotgenes/pi-packages",
  "type": "module",
  "description": "Monorepo for @gotgenes pi packages",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "prepare": "command -v prek >/dev/null 2>&1 && prek install || echo 'prek not found \u2014 skipping hook install (see README)'",
    "check": "pnpm -r run check",
    "test": "pnpm -r run test",
    "lint": "biome check . && eslint packages/ && rumdl check .",
    "lint:fix": "biome check --write . && eslint packages/ --fix && rumdl fmt .",
    "format": "biome format --write .",
    "fallow": "fallow",
    "fallow:audit": "fallow audit",
    "fallow:health": "fallow health --score --hotspots --targets",
    "fallow:dead-code": "fallow dead-code",
    "fallow:dupes": "fallow dupes"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@eslint/js": "catalog:",
    "eslint": "catalog:",
    "fallow": "catalog:",
    "globals": "catalog:",
    "rumdl": "^0.1.93",
    "typescript-eslint": "catalog:"
  }
}
